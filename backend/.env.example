# Copy this file to  backend/.env  and fill in a key to use a real LLM.
# With nothing set, the agents use the offline MockLLM (analysis still runs for real).

HELIX_CORS_ORIGINS=http://localhost:3000

# ── Free-tier API LLM (recommended: Groq — free, fast, no card) ──────────────
# 1. Get a key at https://console.groq.com/keys
# 2. Uncomment the three lines below and paste your key.
# HELIX_LLM_BASE_URL=https://api.groq.com/openai/v1
# HELIX_LLM_API_KEY=gsk_your_key_here
# HELIX_LLM_MODEL=llama-3.3-70b-versatile

# ── Alternatives (also free tier, OpenAI-compatible) ─────────────────────────
# Google Gemini:
#   HELIX_LLM_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai
#   HELIX_LLM_API_KEY=your_gemini_key      (https://aistudio.google.com/apikey)
#   HELIX_LLM_MODEL=gemini-2.0-flash
# OpenRouter (has free :free models):
#   HELIX_LLM_BASE_URL=https://openrouter.ai/api/v1
#   HELIX_LLM_API_KEY=sk-or-...
#   HELIX_LLM_MODEL=deepseek/deepseek-chat-v3-0324:free
# Z.ai (GLM models, OpenAI-compatible):
#   HELIX_LLM_BASE_URL=https://api.z.ai/api/paas/v4
#   HELIX_LLM_API_KEY=your_zai_key        (https://z.ai → API Keys)
#   HELIX_LLM_MODEL=glm-4.6

# ── Hybrid (per-role overrides; e.g. local Coder + hosted Reporter) ──────────
# HELIX_CODER_BASE_URL=http://localhost:11434/v1   (Ollama)
# HELIX_CODER_MODEL=deepseek-coder

# ── Hardened code execution (optional) ───────────────────────────────────────
# Run agent-generated code in an E2B microVM (true VM isolation + hard timeout)
# instead of the in-process RestrictedPython sandbox. Get a key at https://e2b.dev
# Leave unset to use RestrictedPython (zero-dependency fallback).
# E2B_API_KEY=e2b_your_key_here
