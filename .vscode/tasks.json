{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Helix: backend (FastAPI)",
      "type": "shell",
      "command": "python -m uvicorn app.main:app --reload --port 8000",
      "options": { "cwd": "${workspaceFolder}/backend" },
      "isBackground": true,
      "presentation": { "group": "helix", "panel": "dedicated", "reveal": "always" },
      "problemMatcher": []
    },
    {
      "label": "Helix: frontend (Next.js)",
      "type": "shell",
      "command": "npm run dev",
      "options": { "cwd": "${workspaceFolder}/frontend" },
      "isBackground": true,
      "presentation": { "group": "helix", "panel": "dedicated", "reveal": "always" },
      "problemMatcher": []
    },
    {
      "label": "Helix: run all",
      "dependsOn": [
        "Helix: backend (FastAPI)",
        "Helix: frontend (Next.js)"
      ],
      "dependsOrder": "parallel",
      "problemMatcher": []
    }
  ]
}
